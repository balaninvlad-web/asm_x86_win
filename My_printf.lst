     2                                  ;: My_printf.asm                    (c)VOV4IK,2026
     3                                  ;:================================================
     4                                  ; My_printf – аналог printf для Windows x64 (NASM)
     5                                  ; Поддерживает форматы: %c, %s, %d, %u, %x, %o, %b (двоичный), %%
     6                                  
     7                                  ;nasm -f win64 My_printf.asm -o My_printf.obj -l "My_printf.lst"
     8                                  
     9                                  
    10                                  ; Импортируем функции из kernel32.dll
    11                                  extern GetStdHandle         ; получить хендл
    12                                  extern WriteConsoleA        ; ф_ция записи в консоль 
    13                                  
    14                                  section .data
    15 00000000 0000000000000000            hConsole dq 0          ; переменная для хэндла
    16                                  
    17                                  section .text
    18                                  global My_printf:          ; глобальная видна при линковке с Си кодом
    19                                  
    20                                  ; ============================================================================
    21                                  ; My_printf – главная функция
    22                                  ; Вход:  RCX = форматная строка (const char*)
    23                                  ;        RDX = 1-й аргумент (для %d, %c и т.д.)
    24                                  ;        R8  = 2-й аргумент
    25                                  ;        R9  = 3-й аргумент
    26                                  ;        [RSP+40] = 4-й аргумент, далее по стеку (соглашение Windows x64)
    27                                  ; Выход: нет (void)
    28                                  ; Регистры: сохраняет все используемые (r9, r8, rdx, rcx, rsi, rdi, rbp)
    29                                  ; ============================================================================
    30                                  My_printf:        
    31 00000000 4151                            push r9
    32 00000002 4150                            push r8
    33 00000004 52                              push rdx           ; 1-й аргумент      
    34 00000005 51                              push rcx           ; фотматная строка
    35 00000006 56                              push rsi
    36 00000007 57                              push rdi
    37 00000008 55                              push rbp
    38                                          ; восстанавливаем указатели на аргументы из стека
    39 00000009 488B7C2418                      mov rdi, [rsp+24]  ; RCX
    40 0000000E 488D6C2420                      lea rbp, [rsp + 32]; 1-й аргумент
    41                                          ; получаю хендл консольного вывода 
    42 00000013 48833D(00000000)00              cmp qword [rel hConsole], 0
    43 0000001B 7511                            jne .print_loop
    44 0000001D B9F5FFFFFF                      mov ecx, -11       ; STD_OUTPUT_HANDLE
    45 00000022 E8(00000000)                    call GetStdHandle
    46 00000027 488905(00000000)                mov [rel hConsole], rax
    47                                  
    48                                  ; основной цикл вывода форматной строки
    49                                  .print_loop:
    50 0000002E 803F00                          cmp byte [rdi], 0
    51 00000031 741E                            je .eoprnt        ; \0      
    52                                  
    53 00000033 803F25                          cmp byte [rdi], '%'
    54 00000036 740C                            je .print_value   
    55                                          ; прямой обычный вывод
    56 00000038 8A07                            mov al, [rdi]
    57 0000003A 48FFC7                          inc rdi
    58 0000003D E892000000                      call Print_char
    59 00000042 EBEA                            jmp .print_loop
    60                                  
    61                                  .print_value:
    62 00000044 48FFC7                          inc rdi             ; пропуск %
    63 00000047 E80F000000                      call Print_value    ;обработка спецификатора
    64 0000004C 48FFC7                          inc rdi             ; пропус спецификатора
    65 0000004F EBDD                            jmp .print_loop
    66                                  .eoprnt:
    67 00000051 5D                              pop rbp
    68 00000052 5F                              pop rdi
    69 00000053 5E                              pop rsi
    70 00000054 59                              pop rcx
    71 00000055 5A                              pop rdx
    72 00000056 4158                            pop r8
    73 00000058 4159                            pop r9
    74                                  
    75 0000005A C3                              ret
    76                                  ; ============================================================================
    77                                  ; Print_value – диспетчер спецификаторов
    78                                  ; Вход:  RDI указывает на символ после '%'
    79                                  ;        RBP указывает на текущий аргумент
    80                                  ; Выход: RBP сдвинут на 8 
    81                                  ;        RDI не меняется 
    82                                  ; ============================================================================
    83                                  Print_value:
    84                                          ; обрабатываю %
    85 0000005B 803F25                          cmp byte [rdi], '%'
    86 0000005E 7423                            je .print_procent
    87                                          ; проверка на [a-z]
    88 00000060 803F61                          cmp byte [rdi], 'a'
    89 00000063 7227                            jb .erorr
    90                                  
    91 00000065 803F7A                          cmp byte [rdi], 'z'
    92 00000068 7722                            ja .erorr
    93                                          ; вычисление индекса для таблицы переходов
    94 0000006A 4831C9                          xor rcx, rcx
    95 0000006D 8A0F                            mov cl, [rdi]
    96 0000006F 80E961                          sub cl, 'a'                    ; rcx = индекс от 0 до 25
    97 00000072 48C1E103                        shl rcx, 3                     ; умножаем на 8 (размер qword)
    98 00000076 488D05(08000000)                lea rax, [rel jump_table]      ; загружаем RIP-relative адрес таблицы
    99 0000007D 488B0C08                        mov rcx, [rax + rcx]           ; загружаем адрес обработчика
   100 00000081 FFE1                            jmp rcx
   101                                  ; обработка %
   102                                  .print_procent:
   103 00000083 B025                            mov al, '%'
   104 00000085 E84A000000                      call Print_char
   105 0000008A EB16                            jmp .jmp_after_output
   106                                  ; обработка ошибочного символа
   107                                  .erorr:
   108 0000008C B025                            mov al, '%'
   109 0000008E E841000000                      call Print_char
   110 00000093 8A07                            mov al, [rdi]   ; символ типа
   111 00000095 E83A000000                      call Print_char
   112 0000009A 48FFC7                          inc rdi
   113 0000009D 48FFC7                          inc rdi
   114 000000A0 EB00                            jmp .jmp_after_output
   115                                  
   116                                  ; общая точка выхода после обработки спецификатора
   117                                  .jmp_after_output:
   118 000000A2 4883C508                        add rbp, 8
   119 000000A6 C3                              ret
   120                                  ; обработка %с
   121                                  Print_char_func:
   122 000000A7 8A4500                          mov al, byte [rbp]   
   123 000000AA E825000000                      call Print_char
   124 000000AF EBF1                            jmp Print_value.jmp_after_output
   125                                  
   126                                  ; обработка дефолтного кейса
   127                                  Default_case:
   128 000000B1 B03F                            mov al, '?'
   129 000000B3 E81C000000                      call Print_char
   130 000000B8 48FFC7                          inc rdi
   131                                  .jmp_after_output:
   132                                  
   133                                  ; обработка %s
   134                                  Print_string:
   135 000000BB 57                              push rdi            ; соханяю rdi
   136 000000BC 488B7D00                        mov rdi, [rbp]      ; и кладу туда ардес из аргумента
   137                                  .print_str_loop:
   138 000000C0 803F00                          cmp byte [rdi], 0
   139 000000C3 740C                            je .eoprnt
   140 000000C5 8A07                            mov al, byte [rdi]
   141 000000C7 E808000000                      call Print_char
   142 000000CC 48FFC7                          inc rdi
   143 000000CF EBEF                            jmp .print_str_loop
   144                                  .eoprnt:
   145 000000D1 5F                              pop rdi             ; восстанавливаю
   146 000000D2 EBCE                            jmp Print_value.jmp_after_output 
   147                                          
   148                                  ; ============================================================================
   149                                  ; Print_char – вывод одного символа через WriteConsoleA
   150                                  ; Вход: AL – символ для вывода
   151                                  ; ============================================================================
   152                                  
   153                                  Print_char:
   154                                          ; сохраняю регисты котрые может испортить функция WriteConsoleA
   155 000000D4 50                              push rax
   156 000000D5 51                              push rcx
   157 000000D6 52                              push rdx
   158 000000D7 4150                            push r8
   159 000000D9 4151                            push r9
   160 000000DB 4152                            push r10
   161 000000DD 4153                            push r11
   162                                          ; помещаю символ в буффер
   163 000000DF 8805(00000000)                  mov [rel out_char_buf], al
   164                                  
   165 000000E5 4883EC20                        sub rsp, 32                     ; резервирую под WriteConsole
   166 000000E9 488B0D(00000000)                mov rcx, [rel hConsole]         ; хендл консоли
   167 000000F0 488D15(00000000)                lea rdx, [rel out_char_buf]     ; адрес буфера
   168 000000F7 41B801000000                    mov r8d, 1                      ; количесво выводимых символов
   169 000000FD 4C8D0D(01000000)                lea r9, [rel written]           ; указатель на переменную 
   170 00000104 48C7042400000000                mov qword [rsp], 0              ; резерв обоссаный ублюдок
   171 0000010C E8(00000000)                    call WriteConsoleA
   172 00000111 4883C420                        add rsp, 32                      ; освобождаю стек
   173                                  
   174 00000115 415B                            pop r11
   175 00000117 415A                            pop r10
   176 00000119 4159                            pop r9
   177 0000011B 4158                            pop r8
   178 0000011D 5A                              pop rdx
   179 0000011E 59                              pop rcx
   180 0000011F 58                              pop rax
   181 00000120 C3                              ret
   182                                  
   183                                  ; ============================================================================
   184                                  ; Обработчики числовых форматов: %d, %u, %x, %o, %b
   185                                  ; Каждый загружает значение из аргумента, расширяет знак для %d,
   186                                  ; и вызывает универсальную функцию Print_number.
   187                                  ; ============================================================================
   188                                  Print_binary:
   189 00000121 488B4500                        mov rax, [rbp]
   190 00000125 BA02000000                      mov rdx, 2          ; основание
   191 0000012A 4831C9                          xor rcx, rcx        ; флаг беззнаковости
   192 0000012D E860000000                      call Print_number
   193 00000132 E96BFFFFFF                      jmp Print_value.jmp_after_output
   194                                  
   195                                  Print_decimal:
   196                                          Print_decimal:
   197 00000137 8B4500                          mov eax, [rbp]      
   198 0000013A 4898                            cdqe                ; расширю знак до 64 бит (изначально лежит 32битное)
   199 0000013C BA0A000000                      mov rdx, 10         ; основание
   200 00000141 B901000000                      mov rcx, 1          ; флаг знаковости
   201 00000146 E847000000                      call Print_number
   202 0000014B E952FFFFFF                      jmp Print_value.jmp_after_output
   203                                  
   204                                  Print_oct:
   205 00000150 488B4500                        mov rax, [rbp]
   206 00000154 BA08000000                      mov rdx, 8          ; основание 
   207 00000159 4831C9                          xor rcx, rcx        ; флаг беззнаковости
   208 0000015C E831000000                      call Print_number
   209 00000161 E93CFFFFFF                      jmp Print_value.jmp_after_output
   210                                  
   211                                  Print_hex:
   212 00000166 488B4500                        mov rax, [rbp]
   213 0000016A BA10000000                      mov rdx, 16         ; я заколебался уже понятно
   214 0000016F 4831C9                          xor rcx, rcx  
   215 00000172 E81B000000                      call Print_number
   216 00000177 E926FFFFFF                      jmp Print_value.jmp_after_output
   217                                  
   218                                  Print_unsigned:
   219 0000017C 488B4500                        mov rax, [rbp]
   220 00000180 BA0A000000                      mov rdx, 10
   221 00000185 4831C9                          xor rcx, rcx
   222 00000188 E805000000                      call Print_number
   223 0000018D E910FFFFFF                      jmp Print_value.jmp_after_output
   224                                  
   225                                  ; ============================================================================
   226                                  ; Print_number – преобразвывает число в строку и выводит
   227                                  ; Вход:  RAX = 64-битное число (для знаковых – уже расширенное)
   228                                  ;        RDX = основание системы счисления (2, 8, 10, 16)
   229                                  ;        RCX = 1 если нужно выводить знак (для %d), иначе 0
   230                                  ; ============================================================================
   231                                  Print_number:
   232 00000192 53                              push rbx
   233 00000193 51                              push rcx
   234 00000194 52                              push rdx
   235 00000195 56                              push rsi
   236 00000196 57                              push rdi
   237                                  
   238                                          ; Проверка на отрицательное и знак
   239 00000197 4885C9                          test rcx, rcx
   240 0000019A 7411                            jz .unsigned
   241 0000019C 4885C0                          test rax, rax
   242 0000019F 790C                            jns .positive
   243                                          ; отрицательное: выводим минус, берём модуль
   244 000001A1 50                              push rax
   245 000001A2 B02D                            mov al, '-'
   246 000001A4 E82BFFFFFF                      call Print_char
   247 000001A9 58                              pop rax
   248 000001AA 48F7D8                          neg rax
   249                                  .positive:
   250                                  .unsigned:
   251 000001AD 4889D3                          mov rbx, rdx                   ; сохраняю основание
   252                                  
   253                                          ; Буфер в number_buf, заполняем с конца
   254 000001B0 488D35(24000000)                lea rsi, [rel number_buf + 31] ; указатель на последний байт буфера
   255 000001B7 C60600                          mov byte [rsi], 0              ; терминатор
   256                                  
   257                                          ; Особый случай: ноль
   258 000001BA 4885C0                          test rax, rax
   259 000001BD 7509                            jnz .convert_loop
   260 000001BF B030                            mov al, '0'
   261 000001C1 E80EFFFFFF                      call Print_char
   262 000001C6 EB2D                            jmp .done
   263                                  
   264                                  .convert_loop:
   265 000001C8 4831D2                          xor rdx, rdx
   266 000001CB 48F7F3                          div rbx                 ; rax = частное, rdx = остаток
   267                                          ; Преобразуем остаток в символ
   268 000001CE 80FA09                          cmp dl, 9
   269 000001D1 7605                            jbe .digit
   270 000001D3 80C237                          add dl, 'A' - 10       ; для основания 16
   271 000001D6 EB03                            jmp .store
   272                                  .digit:
   273 000001D8 80C230                          add dl, '0'
   274                                  .store:
   275 000001DB 48FFCE                          dec rsi                ; сдвиг указателя
   276 000001DE 8816                            mov [rsi], dl          ; сохранение цифры в буффер
   277 000001E0 4885C0                          test rax, rax
   278 000001E3 75E3                            jnz .convert_loop
   279                                  
   280                                          ; Вывожу цифры из буфера
   281                                  .print_digits:
   282 000001E5 8A06                            mov al, [rsi]
   283 000001E7 3C00                            cmp al, 0
   284 000001E9 740A                            je .done
   285 000001EB E8E4FEFFFF                      call Print_char
   286 000001F0 48FFC6                          inc rsi
   287 000001F3 EBF0                            jmp .print_digits
   288                                  
   289                                  .done:
   290 000001F5 5F                              pop rdi
   291 000001F6 5E                              pop rsi
   292 000001F7 5A                              pop rdx
   293 000001F8 59                              pop rcx
   294 000001F9 5B                              pop rbx
   295 000001FA C3                              ret
