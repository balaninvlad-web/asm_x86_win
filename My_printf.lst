   297                                  ; Неинициализированные данные (BSS)
   298                                  ; ============================================================================
   299                                  section .bss
   300 00000000 ??                          out_char_buf resb 1          ; буфер для одного символа (используется в Print_char)
   301 00000001 ????????                    written resd 1               ; сюда WriteConsoleA пишет количество выведенных символов
   302 00000005 <res 20h>                   number_buf resb 32           ; буфер для преобразования чисел (до 32 цифр)
   303                                  
   304                                  section .data
   305                                  ; ============================================================================
   306                                  ; Таблица переходов для спецификаторов от 'a' до 'z'
   307                                  ; ============================================================================
   308                                  jump_table:
   309 00000008 [B100000000000000]              dq Default_case            ; a
   310 00000010 [2101000000000000]              dq Print_binary            ; b
   311 00000018 [A700000000000000]              dq Print_char_func        ; c
